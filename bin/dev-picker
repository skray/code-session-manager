#!/bin/bash
# Persistent picker for tmux dev sessions
# Uses a single fzf instance with reload — fzf never exits,
# so mouse tracking is managed cleanly with no escape sequence leaks.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SELF="$SCRIPT_DIR/$(basename "$0")"
DEV_DIR="$HOME/dev"
CACHE_DIR="$HOME/.cache/dev-picker/pr"

get_main_client() {
    tmux list-clients -F '#{client_tty}|#{session_name}' 2>/dev/null | grep -v '|_picker$' | head -1 | cut -d'|' -f1
}

read_pr_cache() {
    local path="$1" branch="$2"
    [ "$branch" = "-" ] && return

    local remote_url slug
    remote_url=$(git -C "$path" remote get-url origin 2>/dev/null) || return
    case "$remote_url" in
        git@github.com:*) slug="${remote_url#git@github.com:}" ;;
        *github.com/*)    slug="${remote_url#*github.com/}" ;;
        *)                return ;;
    esac
    slug="${slug%.git}"

    local cache_file="$CACHE_DIR/${slug%%/*}/${slug#*/}/$branch.json"
    [ -f "$cache_file" ] || return

    local number review checks_pass checks_fail checks_pending human_comments bot_comments last_commenter last_comment_at
    read -r number review checks_pass checks_fail checks_pending human_comments bot_comments last_commenter last_comment_at < <(
        jq -r '[.number, .review, .checks_pass, .checks_fail, .checks_pending, .human_comments, .bot_comments, .last_commenter, .last_comment_at] | @tsv' "$cache_file" 2>/dev/null
    ) || return

    [ -z "$number" ] || [ "$number" = "null" ] && return

    local review_icon
    case "$review" in
        MERGED)            review_icon="🔀" ;;
        APPROVED)          review_icon="✅" ;;
        CHANGES_REQUESTED) review_icon="🔄" ;;
        *)                 review_icon="⏳" ;;
    esac

    # CI checks summary
    local checks_str=""
    local checks_total=$(( checks_pass + checks_fail + checks_pending ))
    if [ "$checks_total" -gt 0 ]; then
        if [ "$checks_fail" -gt 0 ]; then
            checks_str="❌${checks_fail}/${checks_total}"
        elif [ "$checks_pending" -gt 0 ]; then
            checks_str="⏳${checks_pass}/${checks_total}✓"
        else
            checks_str="✓${checks_total}"
        fi
    fi

    local time_str=""
    if [ -n "$last_comment_at" ] && [ "$last_comment_at" != "null" ] && [ "$last_commenter" != "null" ]; then
        local comment_epoch now_epoch ago
        comment_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$last_comment_at" +%s 2>/dev/null) || comment_epoch=0
        now_epoch=$(date +%s)
        ago=$(( now_epoch - comment_epoch ))
        if [ "$ago" -lt 3600 ]; then
            time_str="$((ago / 60))m"
        elif [ "$ago" -lt 86400 ]; then
            time_str="$((ago / 3600))h"
        else
            time_str="$((ago / 86400))d"
        fi
    fi

    local line="◉ #${number} ${review_icon}"
    [ -n "$checks_str" ] && line+=" ${checks_str}"
    line+=" 💬${human_comments} 🤖${bot_comments}"
    if [ -n "$last_commenter" ] && [ "$last_commenter" != "null" ] && [ -n "$time_str" ]; then
        line+=" · ${last_commenter} ${time_str}"
    fi

    printf "%s" "$line"
}

format_sessions() {
    # Outputs NUL-separated multi-line items for fzf --read0 --multi-line
    tmux list-sessions -F '#{session_name}|#{session_path}|#{session_attached}|#{session_activity}' 2>/dev/null | grep -v '^_picker|' | while IFS='|' read -r name path attached activity; do
        # Git branch
        branch=$(git -C "$path" branch --show-current 2>/dev/null)
        [ -z "$branch" ] && branch="-"

        # Pane count
        panes=$(tmux list-panes -t "=$name" 2>/dev/null | wc -l | tr -d ' ')

        # Idle time
        now=$(date +%s)
        idle=$((now - activity))
        if [ "$idle" -lt 60 ]; then
            idle_str="active"
        elif [ "$idle" -lt 3600 ]; then
            idle_str="$((idle / 60))m idle"
        else
            idle_str="$((idle / 3600))h idle"
        fi

        # Line 1: status + name
        if [ "$attached" = "1" ]; then
            printf "● %s\n" "$name"
        else
            printf "○ %s\n" "$name"
        fi

        # Line 2: branch (dimmed)
        printf "  \033[2m⎇ %s\033[0m\n" "$branch"

        # Line 3: panes + idle (dimmed)
        printf "  \033[2m%s panes · %s\033[0m" "$panes" "$idle_str"

        # Line 4: PR status (only if cached data exists)
        local pr_line
        pr_line=$(read_pr_cache "$path" "$branch")
        if [ -n "$pr_line" ]; then
            printf "\n  \033[2m%s\033[0m" "$pr_line"
        fi

        # NUL separator between items
        printf '\0'
    done
}

create_session() {
    local name="$1"
    local dir="$2"

    # Sanitize session name for tmux (replace / and . with -)
    name=$(echo "$name" | tr '/.' '--')

    if tmux has-session -t "=$name" 2>/dev/null; then
        # Session exists, just switch to it
        local main_client
        main_client=$(get_main_client)
        if [ -n "$main_client" ]; then
            tmux switch-client -c "$main_client" -t "$name" 2>/dev/null
        fi
        return 0
    fi

    [ ! -d "$dir" ] && mkdir -p "$dir"

    if ! tmux new-session -d -s "$name" -c "$dir" 2>&1; then
        echo "ERROR: tmux new-session failed for '$name' in $dir"
        read -rp "Press Enter to continue..."
        return 1
    fi

    tmux split-window -t "$name" -v -c "$dir"
    tmux resize-pane -t "$name:1.1" -y 70%
    tmux send-keys -t "$name:1.1" 'claude' Enter

    "$SCRIPT_DIR/dev-code-switch" "$dir"

    local main_client
    main_client=$(get_main_client)
    if [ -n "$main_client" ]; then
        tmux switch-client -c "$main_client" -t "$name" 2>/dev/null
    fi
}

pick_project() {
    # Step 1: Pick a project from ~/dev (only directories, exclude dotfiles and worktree dirs)
    local project
    project=$(ls -1 "$DEV_DIR" | while read -r d; do
        # Only show directories, skip dotfiles, skip worktree dirs (contain a dot after project name)
        [ -d "$DEV_DIR/$d" ] || continue
        [[ "$d" == .* ]] && continue
        # Skip if it looks like a worktree (project.branch pattern where project also exists)
        if [[ "$d" == *.* ]]; then
            local base="${d%%.*}"
            [ -d "$DEV_DIR/$base" ] && continue
        fi
        echo "$d"
    done | fzf \
        --header="Pick a project (Esc to cancel)" \
        --no-sort \
        --reverse \
        --no-info \
        --prompt="project ▶ " \
        --pointer="→" \
        --color="pointer:green,prompt:green" \
    )

    if [ -z "$project" ]; then
        return
    fi

    # Step 2: Build branch list — worktrees marked, all local+remote branches available
    local worktree_branches=""
    if [ -d "$DEV_DIR/$project" ] && git -C "$DEV_DIR/$project" rev-parse --git-dir &>/dev/null; then
        worktree_branches=$(git -C "$DEV_DIR/$project" worktree list --porcelain 2>/dev/null | awk -v main="$DEV_DIR/$project" '
            /^worktree / { path = substr($0, 10) }
            /^branch /   { if (path != main && path !~ /\/.codex\//) print substr($0, 19) }
        ')
    fi

    local all_branches=""
    if git -C "$DEV_DIR/$project" rev-parse --git-dir &>/dev/null; then
        all_branches=$( {
            git -C "$DEV_DIR/$project" branch --format='%(refname:short)' 2>/dev/null
            git -C "$DEV_DIR/$project" branch -r --format='%(refname:short)' 2>/dev/null \
                | sed 's|^origin/||' | grep -v '^HEAD$'
        } | sort -u )
    fi

    local options="Open directly"
    local wt_set=$'\n'
    while IFS= read -r b; do
        [ -n "$b" ] || continue
        options+=$'\n'"$b (worktree)"
        wt_set+="$b"$'\n'
    done <<< "$worktree_branches"

    while IFS= read -r b; do
        [ -n "$b" ] || continue
        case "$wt_set" in *$'\n'"$b"$'\n'*) continue ;; esac
        options+=$'\n'"$b"
    done <<< "$all_branches"

    # Step 3: Pick branch or type a new one
    # enter: select focused item, or use query if list is empty
    # ctrl-n: always use query as new branch name (bypasses fuzzy matches)
    local choice
    choice=$(echo "$options" | fzf \
        --header="── $project ──────────
enter:select  ctrl-n:new branch" \
        --no-sort \
        --reverse \
        --no-info \
        --prompt="branch ▶ " \
        --pointer="→" \
        --color="pointer:green,prompt:green" \
        --bind 'enter:accept-non-empty+become(echo {q})' \
        --bind 'ctrl-n:become(echo {q})' \
    )

    if [ -z "$choice" ]; then
        return
    fi

    case "$choice" in
        "Open directly")
            create_session "$project" "$DEV_DIR/$project"
            ;;
        *" (worktree)")
            local branch="${choice% (worktree)}"
            local wt_path
            wt_path=$(git -C "$DEV_DIR/$project" worktree list --porcelain 2>/dev/null | awk -v b="$branch" '
                /^worktree / { path = substr($0, 10) }
                /^branch /   { if (substr($0, 8) == "refs/heads/" b) print path }
            ' | head -1)
            if [ -n "$wt_path" ] && [ -d "$wt_path" ]; then
                create_session "$project/$branch" "$wt_path"
            else
                echo "ERROR: Could not find worktree: $branch"
                sleep 2
            fi
            ;;
        *)
            local branch="$choice"

            LOG="/tmp/dev-picker-debug.log"
            echo "=== $(date) ===" >> "$LOG"
            echo "project=$project branch=$branch" >> "$LOG"

            # Fetch first so remote branches are available
            echo "Fetching $project..."
            echo "Fetching..." >> "$LOG"
            (cd "$DEV_DIR/$project" && git fetch 2>&1) | tee -a "$LOG"

            # Check if branch exists (local or remote)
            local branch_exists=false
            if git -C "$DEV_DIR/$project" rev-parse --verify "$branch" &>/dev/null; then
                echo "Branch exists locally" >> "$LOG"
                branch_exists=true
            elif git -C "$DEV_DIR/$project" rev-parse --verify "origin/$branch" &>/dev/null; then
                echo "Branch exists on remote" >> "$LOG"
                branch_exists=true
            else
                echo "Branch does not exist" >> "$LOG"
            fi

            # Run wt with visible output so user sees progress (npm install, etc.)
            echo "Creating worktree for $branch..."
            if [ "$branch_exists" = true ]; then
                echo "Running: wt switch $branch --no-cd --yes" >> "$LOG"
                (cd "$DEV_DIR/$project" && wt switch "$branch" --no-cd --yes 2>&1) | tee -a "$LOG"
            else
                echo "Running: wt switch --create $branch --base origin/main --no-cd --yes" >> "$LOG"
                (cd "$DEV_DIR/$project" && wt switch --create "$branch" --base origin/main --no-cd --yes 2>&1) | tee -a "$LOG"
            fi
            local wt_exit=${PIPESTATUS[0]}
            echo "wt exit code: $wt_exit" >> "$LOG"

            # Find the worktree path from git by matching branch name in porcelain output
            # (path may not contain the branch name, e.g. .claude/worktrees/random-name)
            local wt_path
            wt_path=$(git -C "$DEV_DIR/$project" worktree list --porcelain 2>/dev/null | awk -v b="$branch" '
                /^worktree / { path = substr($0, 10) }
                /^branch /   { if (substr($0, 8) == "refs/heads/" b) print path }
            ' | head -1)
            echo "wt_path from git worktree list=$wt_path" >> "$LOG"

            if [ -n "$wt_path" ] && [ -d "$wt_path" ]; then
                echo "Found worktree, creating session" >> "$LOG"
                create_session "$project/$branch" "$wt_path"
            else
                echo "FAILED: Could not resolve worktree path" >> "$LOG"
                echo ""
                echo "ERROR: Could not find worktree path for $branch (wt exit: $wt_exit)"
                echo "Check log: $LOG"
                sleep 3
            fi
            ;;
    esac
}

# ── Action dispatch — called by fzf bindings via $SELF --action-* ──

case "${1:-}" in
    --action-list)
        format_sessions
        exit 0
        ;;
    --action-name)
        # Extract session name from first line of multi-line fzf item
        # First line format: "● name" or "○ name"
        echo "$2" | head -1 | awk '{print $2}'
        exit 0
        ;;
    --action-switch)
        name=$("$SELF" --action-name "$2")
        if [ -n "$name" ]; then
            client=$(get_main_client)
            [ -n "$client" ] && tmux switch-client -c "$client" -t "$name" 2>/dev/null
        fi
        exit 0
        ;;
    --action-kill)
        name=$("$SELF" --action-name "$2")
        if [ -n "$name" ]; then
            # Get session path before killing so we can close the VS Code window
            session_path=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep "^${name}|" | head -1 | cut -d'|' -f2)

            client=$(get_main_client)
            if [ -n "$client" ]; then
                current=$(tmux display-message -t "$client" -p '#{session_name}' 2>/dev/null)
                if [ "$current" = "$name" ]; then
                    other=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v "^${name}$" | grep -v '^_picker$' | head -1)
                    if [ -n "$other" ]; then
                        tmux switch-client -c "$client" -t "$other" 2>/dev/null
                    else
                        tmux detach-client -t "$client" 2>/dev/null
                    fi
                fi
            fi
            tmux kill-session -t "$name" 2>/dev/null

            # Close the corresponding VS Code window
            if [ -n "$session_path" ]; then
                osascript -e "
                    tell application \"Visual Studio Code\"
                        repeat with w in (every window)
                            if name of w contains \"$(basename "$session_path")\" then
                                close w
                                exit repeat
                            end if
                        end repeat
                    end tell
                " 2>/dev/null &
            fi
        fi
        exit 0
        ;;
    --action-new)
        pick_project
        exit 0
        ;;
    --action-quit)
        client=$(get_main_client)
        [ -n "$client" ] && tmux detach-client -t "$client" 2>/dev/null
        exit 0
        ;;
    --action-preview)
        name="$2"
        path=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep "^${name}|" | head -1 | cut -d'|' -f2)
        [ -z "$path" ] && exit 0

        short_path=$(echo "$path" | sed "s|$HOME|~|")
        echo "$short_path"
        echo ""

        if git -C "$path" rev-parse --git-dir &>/dev/null; then
            status=$(git -C "$path" status --short 2>/dev/null | head -15)
            if [ -n "$status" ]; then
                echo "Changes:"
                echo "$status"
                echo ""
            else
                echo "Working tree clean"
                echo ""
            fi

            echo "Recent commits:"
            git -C "$path" log --oneline -5 2>/dev/null

            # PR details from cache
            branch=$(git -C "$path" branch --show-current 2>/dev/null)
            if [ -n "$branch" ]; then
                remote_url=$(git -C "$path" remote get-url origin 2>/dev/null)
                case "$remote_url" in
                    git@github.com:*) slug="${remote_url#git@github.com:}" ;;
                    *github.com/*)    slug="${remote_url#*github.com/}" ;;
                    *)                slug="" ;;
                esac
                if [ -n "$slug" ]; then
                    slug="${slug%.git}"
                    cache_file="$CACHE_DIR/${slug%%/*}/${slug#*/}/$branch.json"
                    if [ -f "$cache_file" ]; then
                        echo ""
                        echo "Pull Request:"
                        jq -r '"  #\(.number) \(.title)",
                                "  \(.url)",
                                "  Review: \(.review // "PENDING")",
                                "  Checks: \(.checks_pass // 0) passed, \(.checks_fail // 0) failed, \(.checks_pending // 0) pending",
                                "  Comments: \(.human_comments // 0) human, \(.bot_comments // 0) bot"' \
                            "$cache_file" 2>/dev/null
                    fi
                fi
            fi
        fi
        exit 0
        ;;
    --action-open-pr)
        name=$("$SELF" --action-name "$2")
        path=$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null | grep "^${name}|" | head -1 | cut -d'|' -f2)
        [ -z "$path" ] && exit 0
        branch=$(git -C "$path" branch --show-current 2>/dev/null)
        [ -z "$branch" ] && exit 0
        remote_url=$(git -C "$path" remote get-url origin 2>/dev/null) || exit 0
        case "$remote_url" in
            git@github.com:*) slug="${remote_url#git@github.com:}" ;;
            *github.com/*)    slug="${remote_url#*github.com/}" ;;
            *)                exit 0 ;;
        esac
        slug="${slug%.git}"
        cache_file="$CACHE_DIR/${slug%%/*}/${slug#*/}/$branch.json"
        [ -f "$cache_file" ] || exit 0
        url=$(jq -r '.url // empty' "$cache_file" 2>/dev/null)
        [ -n "$url" ] && open "$url"
        exit 0
        ;;
    --action-header)
        age_str=""
        if [ -d "$CACHE_DIR" ]; then
            newest_mtime=$(find "$CACHE_DIR" -name '*.json' -exec stat -f%m {} + 2>/dev/null | sort -rn | head -1)
            if [ -n "$newest_mtime" ]; then
                now_ts=$(date +%s)
                age=$(( now_ts - newest_mtime ))
                if [ "$age" -lt 60 ]; then
                    age_str="  ↻${age}s"
                elif [ "$age" -lt 3600 ]; then
                    age_str="  ↻$((age / 60))m"
                else
                    age_str="  ↻$((age / 3600))h"
                fi
            fi
        fi
        echo "n:new  x:kill  o:pr  q:quit${age_str}"
        exit 0
        ;;
    --action-bg-refresh)
        SOCK="/tmp/dev-picker.sock"
        while true; do
            "$SCRIPT_DIR/dev-pr-cache" --all 2>/dev/null
            if [ -S "$SOCK" ]; then
                curl --unix-socket "$SOCK" localhost -s -XPOST \
                    -d "reload($SELF --action-list)" 2>/dev/null
                header=$("$SELF" --action-header)
                curl --unix-socket "$SOCK" localhost -s -XPOST \
                    -d "change-header($header)" 2>/dev/null
            fi
            sleep 300
        done
        exit 0
        ;;
esac

# ── Main picker — single persistent fzf instance ──

trap 'rm -f /tmp/dev-picker.sock; kill 0 2>/dev/null' EXIT

format_sessions | fzf \
    --read0 \
    --multi-line \
    --ansi \
    --no-sort \
    --cycle \
    --reverse \
    --no-info \
    --listen=/tmp/dev-picker.sock \
    --header="n:new  x:kill  o:pr  q:quit" \
    --prompt="▶ " \
    --pointer="→" \
    --color="pointer:green,prompt:green" \
    --preview "name=\$(echo {} | head -1 | awk '{print \$2}'); $SELF --action-preview \"\$name\"" \
    --preview-window "bottom,40%" \
    --bind "start:execute-silent($SELF --action-bg-refresh &)" \
    --bind "enter:execute-silent($SELF --action-switch {})+reload($SELF --action-list)+transform-header($SELF --action-header)" \
    --bind "double-click:execute-silent($SELF --action-switch {})+reload($SELF --action-list)+transform-header($SELF --action-header)" \
    --bind "x:execute-silent($SELF --action-kill {})+reload($SELF --action-list)+transform-header($SELF --action-header)" \
    --bind "n:execute($SELF --action-new)+reload($SELF --action-list)+transform-header($SELF --action-header)" \
    --bind "o:execute-silent($SELF --action-open-pr {})" \
    --bind "q:execute-silent($SELF --action-quit)+abort"
