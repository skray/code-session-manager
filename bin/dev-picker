#!/bin/bash
# Persistent picker for tmux dev sessions
# Uses fzf for reliable mouse/keyboard interaction
# Loops so it comes back after each selection

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEV_DIR="$HOME/dev"

get_main_client() {
    tmux list-clients -F '#{client_tty}|#{session_name}' 2>/dev/null | grep -v '|_picker$' | head -1 | cut -d'|' -f1
}

format_sessions() {
    tmux list-sessions -F '#{session_name}|#{session_path}|#{session_attached}' 2>/dev/null | grep -v '^_picker|' | while IFS='|' read -r name path attached; do
        short_path=$(echo "$path" | sed "s|$HOME|~|")
        if [ "$attached" = "1" ]; then
            printf "● %-18s %s\n" "$name" "$short_path"
        else
            printf "  %-18s %s\n" "$name" "$short_path"
        fi
    done
}

create_session() {
    local name="$1"
    local dir="$2"

    # Sanitize session name for tmux (replace / and . with -)
    name=$(echo "$name" | tr '/.' '--')

    if tmux has-session -t "=$name" 2>/dev/null; then
        # Session exists, just switch to it
        local main_client
        main_client=$(get_main_client)
        if [ -n "$main_client" ]; then
            tmux switch-client -c "$main_client" -t "$name" 2>/dev/null
        fi
        return 0
    fi

    [ ! -d "$dir" ] && mkdir -p "$dir"

    tmux new-session -d -s "$name" -c "$dir"
    tmux split-window -t "$name" -v -c "$dir"
    tmux resize-pane -t "$name:1.1" -y 70%
    tmux send-keys -t "$name:1.1" 'claude --dangerously-skip-permissions' Enter

    "$SCRIPT_DIR/dev-code-switch" "$dir"

    local main_client
    main_client=$(get_main_client)
    if [ -n "$main_client" ]; then
        tmux switch-client -c "$main_client" -t "$name" 2>/dev/null
    fi
}

pick_project() {
    # Step 1: Pick a project from ~/dev (only directories, exclude dotfiles and worktree dirs)
    local project
    project=$(ls -1 "$DEV_DIR" | while read -r d; do
        # Only show directories, skip dotfiles, skip worktree dirs (contain a dot after project name)
        [ -d "$DEV_DIR/$d" ] || continue
        [[ "$d" == .* ]] && continue
        # Skip if it looks like a worktree (project.branch pattern where project also exists)
        if [[ "$d" == *.* ]]; then
            local base="${d%%.*}"
            [ -d "$DEV_DIR/$base" ] && continue
        fi
        echo "$d"
    done | fzf \
        --header="Pick a project (Esc to cancel)" \
        --no-sort \
        --reverse \
        --no-info \
        --prompt="project ▶ " \
        --pointer="→" \
        --color="pointer:green,prompt:green" \
    )

    [ -z "$project" ] && return

    # Step 2: Build options list
    local options=""
    options="Open directly"$'\n'"New worktree"

    # Find existing worktrees for this project
    local worktrees=""
    if [ -d "$DEV_DIR/$project" ] && git -C "$DEV_DIR/$project" rev-parse --git-dir &>/dev/null; then
        worktrees=$(git -C "$DEV_DIR/$project" worktree list --porcelain 2>/dev/null | grep "^worktree " | sed 's/^worktree //' | while read -r wt_path; do
            # Skip the main worktree itself
            [ "$wt_path" = "$DEV_DIR/$project" ] && continue
            # Skip codex worktrees
            [[ "$wt_path" == */.codex/* ]] && continue
            # Show just the branch/folder name
            basename "$wt_path"
        done)
    fi

    if [ -n "$worktrees" ]; then
        options="$options"$'\n'"$worktrees"
    fi

    # Step 3: Pick an option
    local choice
    choice=$(echo "$options" | fzf \
        --header="── $project ──────────" \
        --no-sort \
        --reverse \
        --no-info \
        --prompt="▶ " \
        --pointer="→" \
        --color="pointer:green,prompt:green" \
    )

    [ -z "$choice" ] && return

    case "$choice" in
        "Open directly")
            create_session "$project" "$DEV_DIR/$project"
            ;;
        "New worktree")
            printf "Branch name: "
            read -r branch
            [ -z "$branch" ] && return

            LOG="/tmp/dev-picker-debug.log"
            echo "=== $(date) ===" >> "$LOG"
            echo "project=$project branch=$branch" >> "$LOG"

            # Fetch first so remote branches are available
            echo "Fetching..." >> "$LOG"
            (cd "$DEV_DIR/$project" && git fetch --quiet 2>>"$LOG")

            # Check if branch exists (local or remote)
            local branch_exists=false
            if git -C "$DEV_DIR/$project" rev-parse --verify "$branch" &>/dev/null; then
                echo "Branch exists locally" >> "$LOG"
                branch_exists=true
            elif git -C "$DEV_DIR/$project" rev-parse --verify "origin/$branch" &>/dev/null; then
                echo "Branch exists on remote" >> "$LOG"
                branch_exists=true
            else
                echo "Branch does not exist" >> "$LOG"
            fi

            local wt_output
            if [ "$branch_exists" = true ]; then
                echo "Running: wt switch $branch --no-cd --yes" >> "$LOG"
                wt_output=$(cd "$DEV_DIR/$project" && wt switch "$branch" --no-cd --yes 2>&1)
            else
                echo "Running: wt switch --create $branch --base origin/main --no-cd --yes" >> "$LOG"
                wt_output=$(cd "$DEV_DIR/$project" && wt switch --create "$branch" --base origin/main --no-cd --yes 2>&1)
            fi
            echo "wt output: $wt_output" >> "$LOG"

            # Extract path from wt output (looks like: "... @ ~/dev/ai-platform.branch-name")
            local wt_path
            wt_path=$(echo "$wt_output" | grep -o '@ .*' | sed 's/^@ //' | sed "s|^~/|$HOME/|" | head -1)
            echo "wt_path from output=$wt_path" >> "$LOG"

            if [ -n "$wt_path" ] && [ -d "$wt_path" ]; then
                echo "Found worktree, creating session" >> "$LOG"
                create_session "$project/$branch" "$wt_path"
            else
                echo "FAILED: Could not resolve worktree path" >> "$LOG"
                echo "Could not find worktree path for $branch"
                echo "wt said: $wt_output"
                sleep 3
            fi
            ;;
        *)
            # Selected an existing worktree
            local wt_path
            wt_path=$(git -C "$DEV_DIR/$project" worktree list --porcelain 2>/dev/null | grep "^worktree .*${choice}$" | sed 's/^worktree //' | head -1)
            if [ -z "$wt_path" ]; then
                # Fallback: try common patterns
                if [ -d "$HOME/dev/worktrees/${project}/${choice}" ]; then
                    wt_path="$HOME/dev/worktrees/${project}/${choice}"
                elif [ -d "$DEV_DIR/${project}.${choice}" ]; then
                    wt_path="$DEV_DIR/${project}.${choice}"
                fi
            fi
            if [ -n "$wt_path" ] && [ -d "$wt_path" ]; then
                create_session "$project/$choice" "$wt_path"
            else
                echo "Could not find worktree: $choice"
                sleep 2
            fi
            ;;
    esac
}

# Main loop
while true; do
    clear
    sessions=$(format_sessions)

    if [ -z "$sessions" ]; then
        echo "No active sessions."
        echo ""
        echo "Press Enter to create one, or Ctrl-C to quit."
        read -r
        pick_project
        continue
    fi

    choice=$(echo "$sessions" | fzf \
        --header="n:new  x:kill  q:quit" \
        --no-sort \
        --cycle \
        --reverse \
        --no-info \
        --bind="n:abort" \
        --bind="x:abort" \
        --bind="q:abort" \
        --expect="n,x,q" \
        --prompt="▶ " \
        --pointer="→" \
        --color="pointer:green,prompt:green" \
    )

    key=$(echo "$choice" | head -1)
    selection=$(echo "$choice" | tail -1)
    selected_name=$(echo "$selection" | sed 's/^[● ]*//' | awk '{print $1}')

    case "$key" in
        q)
            # Detach the tmux client in the right pane — this exits the
            # "tmux attach" command that dev-start launched, closing the shell
            # and the Ghostty split with it
            client=$(get_main_client)
            if [ -n "$client" ]; then
                tmux detach-client -t "$client" 2>/dev/null
            fi
            break
            ;;
        n)
            pick_project
            ;;
        x)
            if [ -n "$selected_name" ]; then
                # If the main client is on this session, switch it elsewhere first
                client=$(get_main_client)
                if [ -n "$client" ]; then
                    current=$(tmux display-message -t "$client" -p '#{session_name}' 2>/dev/null)
                    if [ "$current" = "$selected_name" ]; then
                        # Find another session to switch to
                        other=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v "^${selected_name}$" | grep -v '^_picker$' | head -1)
                        if [ -n "$other" ]; then
                            tmux switch-client -c "$client" -t "$other" 2>/dev/null
                        else
                            # Last session — detach instead of killing
                            tmux detach-client -t "$client" 2>/dev/null
                        fi
                    fi
                fi
                tmux kill-session -t "$selected_name" 2>/dev/null
            fi
            ;;
        *)
            if [ -n "$selected_name" ]; then
                client=$(get_main_client)
                if [ -n "$client" ]; then
                    tmux switch-client -c "$client" -t "$selected_name" 2>/dev/null
                fi
            fi
            ;;
    esac
done
