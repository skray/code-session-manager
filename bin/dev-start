#!/bin/bash
# Start the dev environment in a single Ghostty window
# Left pane: session picker | Right pane: tmux
#
# Just run: dev-start

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Start tmux server if not running
tmux start-server 2>/dev/null

# Create a default work session if no sessions exist (excluding _picker)
session_count=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^_picker$' | wc -l | tr -d ' ')
if [ "$session_count" -eq 0 ]; then
    tmux new-session -d -s scratch -c "$HOME/dev"
fi

# Kill _picker session if it exists (picker will run outside tmux now)
tmux kill-session -t _picker 2>/dev/null

# Find first non-picker session
first_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -v '^_picker$' | head -1)

# Use Ghostty's native AppleScript API to set up the window
osascript <<EOF
tell application "Ghostty"
    activate

    set pickerCfg to new surface configuration
    set environment variables of pickerCfg to {"PATH=$PATH"}
    set command of pickerCfg to "$SCRIPT_DIR/dev-picker"

    set tmuxCfg to new surface configuration
    set environment variables of tmuxCfg to {"PATH=$PATH"}
    set command of tmuxCfg to "tmux attach -t $first_session"

    set win to new window with configuration pickerCfg
    set pickerPane to terminal 1 of selected tab of win
    set tmuxPane to split pickerPane direction right with configuration tmuxCfg

    -- Shrink the picker (left) pane
    repeat 15 times
        perform action "resize_split:left,10" on pickerPane
    end repeat

    focus tmuxPane
end tell
EOF
